# =============================================================================
# AdversarialShield Environment Configuration
# =============================================================================
#
# SECURITY WARNING: Never commit this file with real credentials!
# Copy this file to .env and fill in your actual values.
#
# Generate secure random keys:
#   SECRET_KEY: python -c 'import secrets; print(secrets.token_urlsafe(32))'
#   Passwords: python -c 'import secrets; print(secrets.token_urlsafe(24))'
#
# =============================================================================

# Environment (development, staging, production, test)
ENVIRONMENT=development

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL (Primary Database)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/adversarial_shield
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=adversarial_shield

# Redis (Cache & Message Broker)
REDIS_URL=redis://:changeme@localhost:6379/0
REDIS_PASSWORD=changeme

# MongoDB (Document Store for Logs & Analytics)
MONGODB_URL=mongodb://admin:changeme@localhost:27017/adversarial_shield
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DB=adversarial_shield

# =============================================================================
# Security Configuration
# =============================================================================

# CRITICAL: Generate a secure random key for production!
# Use: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_IN_PRODUCTION

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# At least one LLM provider is required for attack generation

# OpenAI (GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# HuggingFace (Optional - for open models)
HUGGINGFACE_API_KEY=hf_your-huggingface-key-here

# Ollama (Optional - for local LLM inference)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# SIEM Integration (Optional)
# =============================================================================
# Configure for security event forwarding to SIEM platforms

# Wazuh
WAZUH_API_URL=
WAZUH_API_USERNAME=
WAZUH_API_PASSWORD=

# Splunk
SPLUNK_API_URL=
SPLUNK_API_TOKEN=

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# Model Configuration
# =============================================================================
DEFAULT_LLM_MODEL=gpt-4
DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEFAULT_VISION_MODEL=gpt-4-vision-preview

# =============================================================================
# Red Team Configuration
# =============================================================================
# Attack generation settings
MAX_ATTACK_GENERATION_CONCURRENT=10
ATTACK_TIMEOUT_SECONDS=300

# =============================================================================
# Guardrails Configuration
# =============================================================================
# Detection thresholds (0.0 - 1.0)
INJECTION_DETECTION_THRESHOLD=0.7
ANOMALY_DETECTION_THRESHOLD=0.8

# Feature toggles
PII_DETECTION_ENABLED=true
TOXICITY_DETECTION_ENABLED=true

# =============================================================================
# Frontend Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# =============================================================================
# Monitoring & Observability
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_MULTIMODAL_ATTACKS=true
ENABLE_STATIC_ANALYSIS=true
ENABLE_DYNAMIC_ANALYSIS=true
ENABLE_THREAT_MODELING=true

# =============================================================================
# Celery Configuration (Async Task Processing)
# =============================================================================
# Celery uses REDIS_URL from Database Configuration section
# Additional Celery settings can be configured in backend/core/celery_app.py

# =============================================================================
# Docker-Specific Configuration
# =============================================================================
# When running in Docker, database hostnames change from 'localhost' to service names
# Docker Compose automatically sets these - you typically don't need to change them

# For Docker:
# DATABASE_URL=postgresql://postgres:changeme@postgres:5432/adversarial_shield
# REDIS_URL=redis://:changeme@redis:6379/0
# MONGODB_URL=mongodb://admin:changeme@mongodb:27017/adversarial_shield
